<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="inherit_account_view_move_form">
            <field name="name">account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <label for="from_date" string="Monitoring Period"
                           attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt'))]}"/>
                    <div class="d-flex"
                         attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt'))]}">
                        <field name="from_date" force_save="1" placeholder="Date From"
                               attrs="{'invisible': [('invoice_payment_term_id', '!=', False)]}"/>
                        <span class="o_form_label mx-3 oe_edit_only">
                            -
                        </span>
                        <field name="to_date" placeholder="Date To"/>
                    </div>

                </xpath>
                <xpath expr="//div[@name='journal_div']" position="after">
                    <field name="create_uid"/>
                    <field name="create_date"/>
                </xpath>

                <field name="partner_id" position="after">
                    <field name="ntn"/>
                    <field name="bank_cs_invoice"/>
                    <field name="bank_code_invoice"/>
                    <field name="branch_code_invoice"/>
                    <!--<field name="round_amount"/>-->
                </field>
                <xpath expr="//page/field/tree/field[@name='product_id']" position="after">
                    <field name="effect_on_inventory"/>
                </xpath>
                <!--<xpath expr="//field[@name='address_criteria']" position="after">-->
                <!--<field name="pay_remarks"/>-->
                <!--</xpath>-->
                <xpath expr="//page[@name='other_info']" position="after">
                    <page string="Payment and Collections" name="follow_ups">
                        <group string="Payment Information">
                            <group>
                                <field name="courier"/>
                                <field name="payment_received"/>
                                <field name="po_dd" attrs="{'invisible': [('payment_received','=',False)]}"/>
                                <field name="cheque_no" attrs="{'invisible': [('payment_received','=',False)]}"/>
                                <field name="cheque_date" attrs="{'invisible': [('payment_received','=',False)]}"/>
                                <field name="cheque_date_customer"
                                       attrs="{'invisible': [('payment_received','=',False)]}"/>
                            </group>
                            <group>
                                <field name="actual_amount" attrs="{'invisible': [('payment_received','=',False)]}" string="Payment Received Amount"/>
                                <field name="invoice_no_reference"/>
                                <field name="purchase_order_no"/>
                                <field name="purchase_order_Date"/>
                                <field name="invoice_subject"/>
                            </group>
                        </group>
                        <group string="Follow-ups">
                            <field name="first_call"/>
                            <field name="next_call"/>
                            <field name="remarks"/>
                        </group>
                    </page>
                    <page string="Invoice Properties">
                        <group>
                            <field name="show_tax"/>
                            <field name="hide_purchase_order_detail"/>
                            <field name="hide_cust_ntn_strn_no"/>
                            <field name="hide_mutual_strn_no"/>
                            <field name="hide_mutual_ntn_no"/>
                        </group>
                    </page>
                    <page string="Invoice Details">
                        <group>
                            <group>
                                <field name="maintenance_amount"/>
                                <field name="installation_amount"/>
                            </group>
                            <group>
                                <field name="product_line" readonly="1"/>
                                <field name="product_sales_amount"/>
                                <field name="sales_tax"/>
                                <field name="total_product_amount"/>
                            </group>
                            <group>
                                <field name="monitoring_sales_amount"/>
                                <field name="srb_tax"/>
                                <field name="total_monitoring_amount"/>
                            </group>
                        </group>
                    </page>
                </xpath>

                <!--                <xpath expr="//field[@name='date_invoice']" position="attributes">-->
                <!--                    <attribute name="string">Validation Date</attribute>-->
                <!--                </xpath>-->
                <xpath expr="//field[@name='fiscal_position_id']" position="after">
                    <field name="pay_remarks"/>
                </xpath>
            </field>
        </record>
        <record id="inherit_account_view_move_tree" model="ir.ui.view">
            <field name="name">Account Move Tree</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <field name="date" position="after">
                    <field name="courier"/>
                    <field name="payment_received"/>
                </field>
                <field name="partner_id" position="after">
                    <field name="bank_name"/>
                    <field name="bank_cs_invoice"/>
                    <field name="bank_code_invoice"/>
                    <field name="branch_code_invoice"/>
                    <field name="invoice_date"/>
                </field>
            </field>
        </record>
        <!--==========================Search View=============================-->
        <record model="ir.ui.view" id="inherit_account_view_account_invoice_filter">
            <field name="name">Account Move</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='name']" position="before">
                    <field name="bank_cs_invoice"/>
                    <field name="branch_code_invoice"/>
                    <field name="id"/>
                    <field name="bank_code_invoice"/>
                    <field name="cheque_no"/>
                </xpath>
                <search string="Search Invoice">
                    <group string="Group By">
                        <filter name="courier" string="Couriered" domain="[('courier','=',True)]"/>
                        <filter name="courier" string="Not Couriered" domain="[('courier','=',False)]"/>
                        <filter name="payment_received" string="Payment Received"
                                domain="[('payment_received','=',True)]"/>
                        <filter name="payment_received" string="Payment Not Received"
                                domain="[('payment_received','=',False)]"/>
                    </group>
                    <group string="Head Office">
                        <filter name="bank_cs_invoice" string="Main Branch" domain="[('bank_cs_invoice','=',False)]"/>
                    </group>
                </search>
            </field>
        </record>

