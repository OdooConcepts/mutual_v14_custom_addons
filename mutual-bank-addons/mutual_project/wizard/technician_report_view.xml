<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="oc_technician_report_form" model="ir.ui.view">
            <field name="name">Technician Report Form</field>
            <field name="model">technician.report</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="technician_id" domain="[('department_id','=',1)]"/>
                        </group>
                        <group>
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                        </group>
                        <footer>
                            <button name="print_report" string="Print Report" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_tech_attendance" model="ir.actions.act_window">
            <field name="name">Time In/Out Report</field>
            <field name="res_model">technician.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="oc_technician_report_form"/>
        </record>


         <menuitem
                name="Technician Attendance"
                action="action_tech_attendance"
                id="menu_tech_attendance"
                sequence="3"
                parent="helpdesk.helpdesk_ticket_report_menu_main"/>
    </data>
</odoo>
