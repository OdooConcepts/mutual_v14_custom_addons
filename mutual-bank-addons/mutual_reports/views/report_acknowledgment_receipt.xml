<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!-- Template for the main content of the acknowledgment receipt document -->
        <template id="report_acknowledgment_receipt_document">
            <t t-call="mutual_reports.external_layout_ack">
                <!-- Set a variable 'difference' to calculate amount differences -->
                <t t-set="difference" t-value="o.amount_total - o.residual"/>

                <!-- Start of conditional blocks based on invoice type and state -->
                <div class="col-xs-12" t-if="o.origin">
                    <div class="page" t-if="o.type == 'out_invoice' and (o.state == 'open' or o.state == 'paid') and difference == 0">
                        <div class="row">
                            <div class="col-xs-5 col-xs-offset-7">
                                <address t-field="o.partner_id" t-field-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                                <span t-if="o.partner_id.vat">TIN: <span t-field="o.partner_id.vat"/></span>
                                <div class="col-xs-5" t-if="o.partner_id.phone">
                                    <strong>Phone:</strong>
                                    <p t-field="o.partner_id.phone"/>
                                </div>
                                <div class="col-xs-5" t-if="o.partner_id.mobile">
                                    <strong>Mobile:</strong>
                                    <p t-field="o.partner_id.mobile"/>
                                </div>
                            </div>
                        </div>

                        <h2>Acknowledgment Cheque / Cash</h2>

                        <div class="row mt32 mb32">
                            <div class="col-xs-2">
                                <strong>Date:</strong>
                                <p>_______________</p>
                            </div>
                            <div class="col-xs-2" t-if="o.name">
                                <strong>Description:</strong>
                                <p t-field="o.name"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.cs_number">
                                <strong>CS Number:</strong>
                                <p t-field="o.partner_id.cs_number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.uplink_date">
                                <strong>Uplink Date:</strong>
                                <p t-field="o.partner_id.uplink_date"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_invoice">
                                <strong>Invoice Date:</strong>
                                <p t-field="o.date_invoice"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_due">
                                <strong>Due Date:</strong>
                                <p t-field="o.date_due"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <strong>Source:</strong>
                                <p t-field="o.origin"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <span t-if="o.type == 'out_invoice' and (o.state == 'open' or o.state == 'paid')">
                                    <strong>Invoice</strong>
                                </span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'proforma2'">PRO-FORMA</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                <span t-if="o.type == 'out_refund'">Refund</span>
                                <span t-if="o.type == 'in_refund'">Supplier Refund</span>
                                <span t-if="o.type == 'in_invoice'">Supplier Invoice</span>
                                <span t-field="o.number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.ref">
                                <strong>Customer Code:</strong>
                                <p t-field="o.partner_id.ref"/>
                            </div>
                            <div class="col-xs-2" t-if="o.reference">
                                <strong>Reference:</strong>
                                <p t-field="o.reference"/>
                            </div>
                        </div>

                        <table class="table table-condensed">
                            <!-- Add table content here if needed -->
                        </table>

                        <div class="row">
                            <div class="col-xs-12">
                                <table class="table table-condensed">
                                    <tbody>
                                        <tr t-if="o.partner_id">
                                            <td>
                                                <p>Received from thanks from
                                                    <b><span t-field="o.partner_id"/></b>
                                                </p>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.invoice_line" t-as="l">
                                            <td>From <span t-field="l.name"/></td>
                                        </tr>
                                        <tr class="border-black">
                                            <td><strong>Total</strong></td>
                                            <td class="text-right">
                                                <span t-field="o.amount_total" t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/><br/>
                                                <strong t-if="o.partner_id.lang == 'fr_FR'">Arrêté la présente facture à la somme de:</strong>
                                                <strong t-if="o.partner_id.lang == 'en_US'">Amount in words:</strong>
                                                <span t-field="o.amount_to_text"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <p>
                                    <span><span t-field="o.create_date"/><span t-field="o.user_id"/></span>
                                </p>
                            </div>
                            <div class="col-xs-12">
                                <p><strong>Note:</strong> Dear Subscriber, Please check your alarm on daily basis by using panic and other devices.</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Second page template based on different conditions -->
                <div class="col-xs-12" t-if="o.origin">
                    <div class="page" t-if="o.type == 'out_invoice' and o.state == 'paid'">
                        <div class="row">
                            <div class="col-xs-5 col-xs-offset-7">
                                <address t-field="o.partner_id" t-field-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                                <span t-if="o.partner_id.vat">TIN: <span t-field="o.partner_id.vat"/></span>
                                <div t-if="o.partner_id.phone">
                                    <strong>Phone:</strong>
                                    <p t-field="o.partner_id.phone"/>
                                </div>
                                <div t-if="o.partner_id.mobile">
                                    <strong>Mobile:</strong>
                                    <p t-field="o.partner_id.mobile"/>
                                </div>
                            </div>
                        </div>

                        <h2>Receipt</h2>

                        <div class="row mt32 mb32">
                            <div class="col-xs-2" t-if="o.name">
                                <strong>Description:</strong>
                                <p t-field="o.name"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.cs_number">
                                <strong>CS Number:</strong>
                                <p t-field="o.partner_id.cs_number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <span t-if="o.type == 'out_invoice' and (o.state == 'open' or o.state == 'paid')">
                                    <strong>Invoice</strong>
                                </span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'proforma2'">PRO-FORMA</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                <span t-if="o.type == 'out_refund'">Refund</span>
                                <span t-if="o.type == 'in_refund'">Supplier Refund</span>
                                <span t-if="o.type == 'in_invoice'">Supplier Invoice</span>
                                <span t-field="o.number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_invoice">
                                <strong>Invoice Date:</strong>
                                <p t-field="o.date_invoice"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_due">
                                <strong>Due Date:</strong>
                                <p t-field="o.date_due"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <strong>Source:</strong>
                                <p t-field="o.origin"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.ref">
                                <strong>Customer Code:</strong>
                                <p t-field="o.partner_id.ref"/>
                            </div>
                            <div class="col-xs-2" t-if="o.reference">
                                <strong>Reference:</strong>
                                <p t-field="o.reference"/>
                            </div>
                        </div>

                        <table class="table table-condensed">
                            <!-- Add table content here if needed -->
                        </table>

                        <div class="row">
                            <div class="col-xs-12">
                                <table class="table table-condensed">
                                    <tbody>
                                        <tr t-if="o.partner_id">
                                            <td>
                                                <p>Received from thanks from
                                                    <b><span t-field="o.partner_id"/></b>
                                                </p>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.invoice_line" t-as="l">
                                            <td>From <span t-field="l.name"/></td>
                                        </tr>
                                        <tr class="border-black">
                                            <td><strong>Total</strong></td>
                                            <td class="text-right">
                                                <span t-field="o.amount_total" t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/><br/>
                                                <strong t-if="o.partner_id.lang == 'fr_FR'">Arrêté la présente facture à la somme de:</strong>
                                                <strong t-if="o.partner_id.lang == 'en_US'">Amount in words:</strong>
                                                <span t-field="o.amount_to_text"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <p>
                                    <span><span t-field="o.create_date"/><span t-field="o.user_id"/></span>
                                </p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Third page template based on different conditions -->
                <div class="col-xs-12" t-if="o.origin">
                    <div class="page" t-if="o.type == 'out_invoice' and o.state == 'open' and difference != 0">
                        <div class="row">
                            <div class="col-xs-5 col-xs-offset-7">
                                <address t-field="o.partner_id" t-field-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"/>
                                <span t-if="o.partner_id.vat">TIN: <span t-field="o.partner_id.vat"/></span>
                                <div t-if="o.partner_id.phone">
                                    <strong>Phone:</strong>
                                    <p t-field="o.partner_id.phone"/>
                                </div>
                                <div t-if="o.partner_id.mobile">
                                    <strong>Mobile:</strong>
                                    <p t-field="o.partner_id.mobile"/>
                                </div>
                            </div>
                        </div>

                        <h2>Receipt</h2>

                        <div class="row mt32 mb32">
                            <div class="col-xs-2" t-if="o.name">
                                <strong>Description:</strong>
                                <p t-field="o.name"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.cs_number">
                                <strong>CS Number:</strong>
                                <p t-field="o.partner_id.cs_number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <span t-if="o.type == 'out_invoice' and (o.state == 'open' or o.state == 'paid')">
                                    <strong>Invoice</strong>
                                </span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'proforma2'">PRO-FORMA</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                <span t-if="o.type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                <span t-if="o.type == 'out_refund'">Refund</span>
                                <span t-if="o.type == 'in_refund'">Supplier Refund</span>
                                <span t-if="o.type == 'in_invoice'">Supplier Invoice</span>
                                <span t-field="o.number"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_invoice">
                                <strong>Invoice Date:</strong>
                                <p t-field="o.date_invoice"/>
                            </div>
                            <div class="col-xs-2" t-if="o.date_due">
                                <strong>Due Date:</strong>
                                <p t-field="o.date_due"/>
                            </div>
                            <div class="col-xs-2" t-if="o.origin">
                                <strong>Source:</strong>
                                <p t-field="o.origin"/>
                            </div>
                            <div class="col-xs-2" t-if="o.partner_id.ref">
                                <strong>Customer Code:</strong>
                                <p t-field="o.partner_id.ref"/>
                            </div>
                            <div class="col-xs-2" t-if="o.reference">
                                <strong>Reference:</strong>
                                <p t-field="o.reference"/>
                            </div>
                        </div>

                        <table class="table table-condensed">
                            <!-- Add table content here if needed -->
                        </table>

                        <div class="row">
                            <div class="col-xs-12">
                                <table class="table table-condensed">
                                    <tbody>
                                        <tr t-if="o.partner_id">
                                            <td>
                                                <p>Received from thanks from
                                                    <b><span t-field="o.partner_id"/></b>
                                                </p>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.invoice_line" t-as="l">
                                            <td>From <span t-field="l.name"/></td>
                                        </tr>
                                        <tr class="border-black">
                                            <td><strong>Total Amount</strong></td>
                                            <td class="text-right">
                                                <span t-field="o.amount_total" t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/><br/>
                                                <strong t-if="o.partner_id.lang == 'fr_FR'">Arrêté le présent devis/commande à la somme de:</strong>
                                                <strong t-if="o.partner_id.lang == 'en_US'">Amount in words:</strong>
                                                <span t-field="o.amount_to_text"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Paid</strong></td>
                                            <td class="text-right">
                                                <span t-esc="difference" t-esc-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Balance</strong></td>
                                            <td class="text-right">
                                                <span t-field="o.residual" t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <p>
                                    <span><span t-field="o.create_date"/><span t-field="o.user_id"/></span>
                                </p>
                            </div>
                        </div>

                    </div>
                </div>
            </t>
        </template>

        <!-- Template to call the main document template for each record -->
        <template id="report_acknowledgment_receipt">
            <t t-call="report.html_container">
                <t t-foreach="doc_ids" t-as="doc_id">
                    <t t-call="report_acknowledgment_receipt_document">
                        <t t-set="o" t-value="doc_id"/>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
