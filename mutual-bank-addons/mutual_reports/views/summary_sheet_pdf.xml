<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="summary_sheet_pdf">
            <t t-call="web.external_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="summary_sheet">
                        <t t-call="web.internal_layout">
                            <t t-if="summary_sheet.sale_tax and not summary_sheet.maintenance_charges">
                                <strong>Customer Information:</strong>
                                <span t-field="summary_sheet.customer"/><br/>
                                <span t-field="summary_sheet.customer.street"/><br/>
                                <span t-field="summary_sheet.customer.street2"/><br/><br/>
                                <table class="table table-condensed">
                                    <thead style="background:#D3D3D3">
                                        <tr>
                                            <th>Serial Number</th>
                                            <th>Branch Code</th>
                                            <th>First Address</th>
                                            <th>Second Address</th>
                                            <th>Service Period</th>
                                            <th>Total Monitoring</th>
                                            <th>Provincial Sales Tax</th>
                                            <th>Grand Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="i" t-value="1"/>
                                        <tr t-foreach="summary_sheet.summary_sheet" t-as="l">
                                            <td><span t-esc="i"/></td>
                                            <td><span t-field="l.branch_code"/></td>
                                            <td><span t-field="l.address1"/></td>
                                            <td><span t-field="l.address2"/></td>
                                            <td><span t-field="l.service_period"/></td>
                                            <td><span t-field="l.total_moni"/></td>
                                            <td><span t-field="l.sales_tax_amount"/></td>
                                            <td><span t-field="l.total_amount_with_sales_tax"/></td>
                                            <t t-set="i" t-value="i+1"/>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="row">
                                    <div class="col-xs-4 pull-right">
                                        <table class="table table-condensed" style="font-size:16px">
                                            <tr class="border-black">
                                                <td><strong>Total</strong></td>
                                                <td class="text-right">
                                                    <strong><span t-esc="round(summary_sheet.total)"/></strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </t>
                            <t t-if="not summary_sheet.sale_tax">
                                <p><strong>Customer Information</strong></p>
                                <span t-field="summary_sheet.customer"/><br/>
                                <span t-field="summary_sheet.customer.street"/><br/>
                                <span t-field="summary_sheet.customer.street2"/><br/><br/>
                                <table class="table table-condensed">
                                    <thead style="background:#D3D3D3">
                                        <tr>
                                            <th>Serial Number</th>
                                            <th>Branch Code</th>
                                            <th>First Address</th>
                                            <th>Second Address</th>
                                            <th>Service Period</th>
                                            <th>Grand Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="i" t-value="1"/>
                                        <tr t-foreach="summary_sheet.summary_sheet" t-as="l">
                                            <td><span t-esc="i"/></td>
                                            <td><span t-field="l.branch_code"/></td>
                                            <td><span t-field="l.address1"/></td>
                                            <td><span t-field="l.address2"/></td>
                                            <td><span t-field="l.service_period"/></td>
                                            <td><span t-field="l.total_amount_with_sales_tax"/></td>
                                            <t t-set="i" t-value="i+1"/>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="row">
                                    <div class="col-xs-4 pull-right">
                                        <table class="table table-condensed" style="font-size:16px">
                                            <tr class="border-black">
                                                <td><strong>Total</strong></td>
                                                <td class="text-right">
                                                    <strong><span t-esc="round(summary_sheet.total)"/></strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </t>
                            <t t-if="summary_sheet.sale_tax and summary_sheet.maintenance_charges">
                                <p><strong>Customer Information</strong></p>
                                <span t-field="summary_sheet.customer"/><br/>
                                <span t-field="summary_sheet.customer.street"/><br/>
                                <span t-field="summary_sheet.customer.street2"/><br/><br/>
                                <table class="table table-condensed">
                                    <thead style="background:#D3D3D3">
                                        <tr>
                                            <th>Serial Number</th>
                                            <th>Branch Code</th>
                                            <th>First Address</th>
                                            <th>Second Address</th>
                                            <th>Service Period</th>
                                            <th>Total Monitoring</th>
                                            <th>Provincial Sales Tax</th>
                                            <th>Maintenance Charges</th>
                                            <th>Grand Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="i" t-value="1"/>
                                        <tr t-foreach="summary_sheet.summary_sheet" t-as="l">
                                            <td><span t-esc="i"/></td>
                                            <td><span t-field="l.branch_code"/></td>
                                            <td><span t-field="l.address1"/></td>
                                            <td><span t-field="l.address2"/></td>
                                            <td><span t-field="l.service_period"/></td>
                                            <td><span t-field="l.total_moni"/></td>
                                            <td><span t-field="l.sales_tax_amount"/></td>
                                            <td><span t-field="l.total_ment"/></td>
                                            <td><span t-field="l.total_amount_with_sales_tax"/></td>
                                            <t t-set="i" t-value="i+1"/>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="row">
                                    <div class="col-xs-4 pull-right">
                                        <table class="table table-condensed" style="font-size:16px">
                                            <tr class="border-black">
                                                <td><strong>Total</strong></td>
                                                <td class="text-right">
                                                    <strong><span t-esc="round(summary_sheet.total)"/></strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </t>
                </div>
            </t>
        </template>
    </data>
</odoo>
