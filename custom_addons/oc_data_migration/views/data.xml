<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="invoice_lines_migration_tree" model="ir.ui.view">
        <field name="name">invoice.lines.migration.tree</field>
        <field name="model">invoice.lines.migration</field>
        <field name="arch" type="xml">
            <tree>
                <field name="old_product_id"/>
                <field name="old_sytem_id"/>
                <field name="old_account_id"/>
                <field name="section"/>
                <field name="effect_on_inventory"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="tax"/>
            </tree>
        </field>
    </record>
    <!--form view-->
    <record id="view_invoice_lines_migration_form" model="ir.ui.view">
        <field name="name">invoice.lines.migration.form</field>
        <field name="model">invoice.lines.migration</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="old_product_id"/>
                        <field name="old_sytem_id"/>
                        <field name="old_account_id"/>
                        <field name="section"/>
                        <field name="effect_on_inventory"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                        <field name="tax"/>
                    </group>
                </group>
            </form>
        </field>
    </record>
    <!--We create action-->
    <record id="invoice_lines_migration_action" model="ir.actions.act_window">
        <field name="name">Invoice Lines Migration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">invoice.lines.migration</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first record!
            </p>
        </field>
    </record>


    <record id="invoice_migration_tree" model="ir.ui.view">
