    <!--Tree view-->
    <record id="data_migration_tree" model="ir.ui.view">
        <field name="name">data.migration.tree</field>
        <field name="model">data.migration</field>
        <field name="arch" type="xml">
            <tree>
                <field name="id"/>
                <field name="company_id"/>
                <field name="partner_id"/>
                <field name="reconcile_id"/>
                <field name="credit"/>
                <field name="journal_id"/>
                <field name="state"/>
                <field name="debit"/>
                <field name="ref"/>
                <field name="account_id"/>
                <field name="period_id"/>
                <field name="date"/>
                <field name="move_id"/>
                <field name="name"/>
                <field name="tax_amount"/>
                <field name="product_id"/>
                <field name="account_tax_id"/>
                <field name="product_uom_id"/>
                <field name="amount_currency"/>
                <field name="quantity"/>
            </tree>
        </field>
    </record>
    <!--form view-->
    <record id="view_data_form" model="ir.ui.view">
        <field name="name">data.migration.form</field>
        <field name="model">data.migration</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="id"/>
                        <field name="company_id"/>
                        <field name="partner_id"/>
                        <field name="reconcile_id"/>
                        <field name="credit"/>
                        <field name="journal_id"/>
                    </group>
                    <group>
                        <field name="state"/>
                        <field name="debit"/>
                        <field name="ref"/>
                        <field name="account_id"/>
                        <field name="period_id"/>
                        <field name="date"/>
                    </group>
                </group>
                <group>
                    <field name="move_id"/>
                    <field name="name"/>
                    <field name="tax_amount"/>
                    <field name="product_id"/>
                    <field name="account_tax_id"/>
                    <field name="product_uom_id"/>
                    <field name="amount_currency"/>
                    <field name="quantity"/>
                </group>
            </form>
        </field>
    </record>
    <!--We create action-->
    <record id="data_action" model="ir.actions.act_window">
        <field name="name">Data Migration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">data.migration</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first record!
            </p>
        </field>
    </record>
    <!-- Top menu item -->
    <menuitem id="data_root"
              name="Data Migration"
              sequence="10"/>
    <menuitem id="data_migration_root"
              name="Data"
              parent="data_root"
              action="data_action"
              sequence="2"/>

    <menuitem id="invoice_migration_root"
              name="Invoice Migration"
              parent="data_root"
              action="invoice_migration_action"
              sequence="3"/>

    <menuitem id="invoice_lines_migration_root"
