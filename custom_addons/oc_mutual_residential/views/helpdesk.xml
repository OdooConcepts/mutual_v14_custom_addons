    <record id="helpdesk_kanban_inherited_kanban" model="ir.ui.view">
        <field name="name">helpdesk.inherit.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <br/>
                <field name="create_date"/>
            </xpath>
        </field>
    </record>

    <record id="oc_complaint_timesheet" model="ir.ui.view">
        <field name="name">Complaint Timesheet</field>
        <field name="model">complaint.timesheet</field>
        <field name="arch" type="xml">
            <tree string="Timesheet List" editable="top">
                <field name="cs_number"/>
                <field name="ticket_id"/>
                <field name="technician_ids" widget="many2many_tags"/>
                <field name="time_in" widget="timesheet_uom"/>
                <field name="time_out" widget="timesheet_uom"/>
                <field name="total_time" widget="timesheet_uom"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="complaint_marker" optional="show"/>
                <field name="time_in_date" optional="hide"/>
                <field name="create_date" optional="hide"/>
                <field name="is_timeout_computed" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="complaint_timesheet_form" model="ir.ui.view">
        <field name="name">complaint.timesheet.form</field>
        <field name="model">complaint.timesheet</field>
        <field name="arch" type="xml">
            <form string="Timesheet Form">
                <sheet>
                    <group>
                        <field name="cs_number"/>
                        <field name="ticket_id"/>
                        <field name="technician_ids" widget="many2many_tags"/>
                        <field name="stage_id"/>
                        <field name="create_date"/>
                    </group>
                    <group>
                        <field name="name"/>
                        <field name="time_in"/>
                        <field name="time_out"/>
                        <field name="total_time"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_complaint_timesheet" model="ir.actions.act_window">
        <field name="name">Tickets Timesheet</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">complaint.timesheet</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create Timesheet
            </p>
        </field>
    </record>

    <menuitem name="TimeIn/Out Activities"
              action="action_complaint_timesheet"
              id="menu_complaint_timesheet"
              parent="helpdesk.helpdesk_ticket_menu_main" sequence="30"/>


</odoo>
