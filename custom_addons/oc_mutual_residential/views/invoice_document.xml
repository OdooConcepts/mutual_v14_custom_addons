<?xml version="1.0" encoding="utf-8" ?>
<odoo>
      <template id="invoice_report_inherit" inherit_id="account.report_invoice_document">
          <xpath expr="//tr[@class='border-black o_subtotal']" position="replace">

          </xpath>
            <xpath expr="//p[@name='payment_communication']" position="after">
                <span t-if="data"><h5>Outstanding Invoices</h5></span>
                <table class="table table-sm o_main_table" t-if="data">
                   <thead>
                      <tr>
                        <th name="th_date" class="text-left"><span>Date</span></th>
                        <th name="th_invoice" class="text-left"><span>Invoice Number</span></th>
                          <th name="th_expenditure_date" class="text-left"><span>Monitoring Period</span></th>
                        <th name="th_amount" class="text-right">Amount</th>
                     </tr>
                   </thead>
                    <tbody class="invoice_tbody">
                        <t t-foreach="data" t-as="invoices">
                            <tr>
                                 <td>
                                      <span t-esc="invoices['invoice_date']"/>
                                 </td>
                                <td>
                                      <span t-esc="invoices['name']"/>
                                </td>
                                <td>
                                    <div class="row">
                                         <span t-esc="monitoring_from"/> to <span t-esc="monitoring_to"/>
                                    </div>
                                </td>
                                <td class="text-right">
                                      <span t-esc="invoices['amount_residual']"/>
                                </td>
                            </tr>
                        </t>
                         <tr>
                             <td></td>
                             <td></td>
                             <td >Subtotal</td>
                             <td class="text-right"><span t-esc="'{0:,.2f}'.format(balance)"/></td>
                   </tr>
                         <tr>
                             <td></td>
                             <td></td>
                             <td>Grand Total</td>
                             <td class="text-right"><span t-esc="'{0:,.2f}'.format(total)"/></td>
                   </tr>
                    </tbody>
                </table>

            </xpath>
     </template>
