<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="project_task_inherited" model="ir.ui.view">
        <field name="name">project.task.line.inherit.line</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='timesheet_ids']/tree/field[@name='unit_amount']" position="before">
                <field name="time_in"/>
                <field name="time_out"/>
                <field name="total_time_duration"/>
            </xpath>
            <xpath expr="//field[@name='timesheet_ids']/tree/field[@name='employee_id']" position="after">
                <field name="multi_tech_other" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//field[@name='timesheet_ids']/tree/field[@name='unit_amount']" position="attributes">
                <attribute name="attrs">{'column_invisible': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>