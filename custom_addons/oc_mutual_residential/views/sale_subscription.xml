<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="sale_subscription_inherited_form" model="ir.ui.view">
        <field name="name">sale_subscription.inherit.form</field>
        <field name="model">sale.subscription</field>
        <field name="inherit_id" ref="sale_subscription.sale_subscription_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cs_number" readonly="1"/>
            </xpath>
             <xpath expr="//field[@name='template_id']" position="after">
                <field name="subscription_type" required="1"/>
            </xpath>
        </field>
    </record>
    <record id="sale_subscription_list_inherited_form" model="ir.ui.view">
        <field name="name">sale_subscription.inherit.tree</field>
        <field name="model">sale.subscription</field>
        <field name="inherit_id" ref="sale_subscription.sale_subscription_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cs_number"/>
            </xpath>
        </field>
    </record>
</odoo>