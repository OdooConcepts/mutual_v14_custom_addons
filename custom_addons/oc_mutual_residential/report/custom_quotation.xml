<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
       <template id="custom_quotation">
           <t t-call='web.html_container'>
               <t t-foreach="docs" t-as="sale_order">
                      <div class="page">
                          <div>
                              <div class="row" style="font-size:16px">
                                   <div style="border:2px solid grey;10px;border-radius:10px;max-width:100%;width:40%;height:auto;padding:10px;display:inline-block;">
                                      <strong style="font-size:12px">Customer's Information:</strong>
                                      <span t-field="sale_order.partner_id.name"/><br/>
                                      <span t-if="sale_order.partner_id.street">
                                          <span t-field="sale_order.partner_id.street"/><br/>
                                      </span>
                                      <span t-if="sale_order.partner_id.street2">
                                          <span t-field="sale_order.partner_id.street2"/><br/>
                                      </span>
                                      <span t-if="sale_order.partner_id.city">
                                          <span t-field="sale_order.partner_id.city"/><br/>
                                      </span>
                                  </div>


                                  <div style="display:inline-block; margin-left:140px;">
                                      <table>
                                          <tr>
                                              <td>
                                               <span t-if="sale_order.create_uid" class="pull-right" style="margin-right:15px">
                                              <strong>Sales Person</strong>
                                              <p t-field="sale_order.create_uid"/>
                                              </span>
                                      </td>
                                             <td>
                                                 <span t-if="sale_order.cs_number"  class="pull-right" style="margin-right:15px">
                                          <strong>CS Number</strong>
                                          <p t-field="sale_order.cs_number"/>
                                      </span>
                                             </td>
                                             <td>
                                                    <span t-if="sale_order.date_order" class="pull-right" style="margin-right:15px">
                                                 <strong>Quotation Date</strong>
                                               <p t-field="sale_order.date_order"/>
                                                </span>
                                              </td>

                                          </tr>
                                      </table>
                                  </div>

                              </div>
                              <!--<h4>Quotation <span t-field="sale_order.name"/>-->
                              <!--</h4>-->
                              <div class="row">
                                  <table  style="font-size:16px;width:100%;">
                                  <thead>
                                      <tr>
                                          <th>Description</th>
                                          <th>Quantity</th>
                                          <th >Unit Price</th>
                                          <th groups="product.group_discount_per_so_line">Discount%</th>
                                          <th>Amount</th>
                                      </tr>
                                  </thead>
                                  <tbody class="invoice_tbody">
                                      <t t-set="current_subtotal" t-value="0"/>
                                      <t t-foreach="sale_order.order_line" t-as="l">
                                          <t t-set="current_subtotal" t-value="current_subtotal + l.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                         <t t-set="current_subtotal" t-value="current_subtotal + l.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                              <tr>
                                                  <t t-if="not l.display_type">
                                                  <td>
                                                      <span t-field="l.name"/>
                                                  </td>
                                                  <td>
                                                      <span t-field="l.product_uom_qty"/>
                                                      <span t-if="l.product_uom.name=='Month(s)'">
                                                          Month(s)
                                                      </span>
                                                      <span t-if="not l.product_uom.name=='Month(s)'">
                                                          <span t-field="l.product_uom"/>
                                                      </span>
                                                  </td>
                                                  <td class="text-right">
                                                      <span t-field="l.price_unit"/>
                                                  </td>
                                                  <td class="text-right" groups="product.group_discount_per_so_line">
                                                      <t t-if="not l.product_id.name == 'GSM Bentel (Italian)'">
                                                          <span t-esc="'%.2f'%(l.discount)"/>
                                                      </t>
                                                  </td>
                                                  <td class="text-right">
                                                      <t t-if="not l.product_id.name == 'GSM Bentel (Italian)'">
                                                          <span t-field="l.price_subtotal"/>
                                                       </t>
                                                       <t t-if="l.product_id.name == 'GSM Bentel (Italian)'">
                                                          <span t-esc="l.price_subtotal"/>
                                                       </t>
                                                  </td>
                                                  </t>
                                                   <t t-if="l.display_type == 'line_section'">
                                                       <td name="td_section_line" colspan="99" style="font-weight: bold; border-bottom: 1px solid black; border-top: 1px solid black; background-color:#eee;">
                                                         <span t-field="l.name"/>
                                                        </td>
                                                        <t t-set="current_section" t-value="l"/>
                                                       <t t-set="current_subtotal" t-value="0"/>
                                                        <t t-if="current_subtotal and l.name !='Monitoring Charges' and l.name !='Additional' and l.name!='Sold System'">
                                                           <t t-set="current_subtotal" t-value="current_subtotal"/>
                                                        </t>
                                                       <t t-if="l.name=='Additional'">
                                                        <t t-set="current_subtotal" t-value="current_subtotal+sale_order.additional_tax"/>
                                                      </t>
                                                      <t t-if="l.name=='Monitoring Charges'">
                                                      <t t-set="current_subtotal" t-value="current_subtotal-sale_order.discounted_amount+sale_order.monitoring_tax"/>
                                                     </t>

                                                   </t>

                                              </tr>

                                                   <t t-if="current_section and (l_last or sale_order.order_line[l_index+1].display_type == 'line_section')">
                                                       <t t-call="oc_mutual_residential.custom_discount_template"/>
                                                       <tr class="is-subtotal text-right">
                                                           <td></td>
                                                           <td></td>
                                                           <td></td>
                                                           <td></td>
                                                      <td colspan="99">
                                                       <strong class="mr16">Subtotal</strong>
                                                       <!--<t t-call="oc_mutual_residential.custom_subtotal_template"/>-->
                                                          <span t-esc="current_subtotal" t-esc-options='{"widget": "monetary", "display_currency": "sale_order.currency_id"}'/>
                                                      </td>
                                              </tr>
                                             </t>
                                      </t>
                                       <tr style="border-top:2px solid black;">
                                          <td></td>
                                          <td></td>
                                          <td></td>
                                          <td></td>
                                         <td><strong>Total</strong></td>
                                          <td class="text-right">
                                              <strong><span t-esc="round(sale_order.amount_total)"/></strong>
                                          </td>
                                      </tr>
                                                <!--<t t-call="oc_mutual_residential.custom_discount_template"/>-->
                                           <!-- Subtotal -->
                                  </tbody>
                              </table>
                              </div>

                          </div>
                          <div style="margin-top:-9px">
                              <div class="col-xs-4 pull-right" style="margin-left:650px;">
                                  <table class="table table-condensed" style="font-size:16px">

                                  </table>
                              </div>
                          </div>
                          <div class="row">
                              <div class="pull-left" style="font-size:18px">
                                  <small>
                                      Terms and Conditions:
                                      <t t-if="not sale_order.terms_conditions=='Additional'">
                                          <ol>
                                              <li>Masonry and carpentry will be responsibility of the customer.</li>
                                              <li>Concealed wiring will be the responsibility of the customer.</li>
                                              <li>100% amount will be paid in advance for additional devices and monitoring.</li>
                                              <li>The devices would be installed by us on the completion of wiring and fixing of windows and doors.</li>
                                              <li>The customer's deputed electrical contractor shall take care of concealed wiring/cabling (Laying of Conduits,Pipes and pulling of wire up to electric points for the alarm devices).</li>
                                              <li>Monitoring and Response will be charged according to prevailing rates at the time of activation of system.</li>
                                              <li>For GSM device, a post paid SIM should be arranged by the customer.</li>
                                              <li><strong>Note : The free basic system shall at all the times remain property of mutual security systems except the additional devices purchased by the customer.</strong></li>
                                          </ol>
                                      </t>
                                      <t t-if="sale_order.terms_conditions=='Additional'">
                                          <ol>
                                              <li>100% Amount will be paid in advance.</li>
                                              <li>Sales tax has been applied at the prevailing rate.</li>
                                              <li>Payment Term: Cash/Cheque.</li>
                                              <li>Please make your Payees A/C Cheque in favor of Mutual Security Systems.</li>
                                              <li>Please write your name and C.M.S / CS.No on the back of cheque. </li>
                                          </ol>
                                      </t>
                                  </small>
                              </div>
                          </div>
                      </div>
               </t>
           </t>
       </template>

    </data>
</odoo>