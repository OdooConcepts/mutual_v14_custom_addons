<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="mutual_header">
            <t t-raw="0"/>
            <div t-if="o.print_with_letter_header" t-attf-class="header o_company_#{o.company_id.id}_layout"
                 t-att-style="report_header_style">
                <div class="row">
                    <div style="max-width:100%; width:100%; height:auto; border-bottom:1px solid black;">
                        <div style="max-width:100%; width:80%; height:auto; display:inline-block; float:left;">
                            <div style="max-width:100%; width:80%; height:auto;">
                                <img t-att-src="'/oc_mutual_residential/static/src/mutual_logo.png'"
                                     style="max-width:100%; width:16%; height:90px;"/>
                            </div>

                            <div style="max-width:100%; width:80%; height:auto; font-size:36px; margin-bottom:10px;">
                                <span>
                                    <t t-if="o.partner_id.company_id.name == 'Mutual Security Systems'">
                                        Mutual Security Systems
                                    </t>
                                    <t t-if="o.partner_id.company_id.name == 'Mutual Security'">
                                        Mutual Security Systems Pvt. Ltd.
                                    </t>
                                    <t t-if="o.partner_id.company_id.name == 'Mutual Security Systems Pvt. Ltd.'">
                                        Mutual Security Systems Pvt. Ltd.
                                    </t>
                                    <t t-if="o.partner_id.company_id.name == 'Mutual Security Systems (SA)'">
                                        Mutual Security Systems
                                    </t>
                                </span>
                            </div>
                        </div>
                        <div style="max-width:100%; width:20%; height:auto; display:inline-block; float:left;">
                            <img t-att-src="'/oc_mutual_residential/static/src/mutual_plate.png'"
                                 style="max-width:100%; width:62%; height:120; float:right;"/>
                        </div>
                    </div>
                </div>
            </div>
        </template>
        <template id="mutual_footer">
            <t t-raw="0"/>
            <div t-if="o.print_with_letter_header" class="footer">
                <div style="font-size:16px;max-width:100%; width:100%;">
                    <span style="font-size:16px; float:left;">
                        <small>
                            <em>
                                <span>Created By:</span>
                                <t t-if="o.create_uid.name=='OdooBot'">
                                    Administrator
                                </t>
                                <t t-if="o.create_uid.name!='OdooBot'">
                                    <span t-field="o.create_uid"/>
                                </t>
                                <span t-field="o.create_date"/>
                                <!--                                    Administrator-->
                            </em>
                        </small>
                    </span>
                    <br/>
                    <span style="font-size:16px; float:left;">
                        <small>
                            <em>
                                <span>Printed By:</span>
                                <span t-esc="user.name"/>
                               <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %I:%M:%S %p')"/>
                            </em>
                        </small>
                    </span>

                    <span style="font-size:16px; float:right;">
                        <t t-if="user.env.company.name == 'Mutual Security Systems'">
                            Mutual Security Systems
                        </t>
                        <t t-if="user.env.company.name == 'Mutual Security'">
                            Mutual Security Systems Pvt. Ltd.
                        </t>
                        <t t-if="user.env.company.name == 'Mutual Security Systems Pvt. Ltd.'">
                            Mutual Security Systems Pvt. Ltd.
                        </t>
                         <t t-if="user.env.company.name == 'Mutual Security Systems (SA)'">
                            Mutual Security Systems
                        </t>
                    </span>
                </div>
                <br/>
                <div style="max-width:100%; width:100%; border-top:1px solid black; text-align:center !important;">
                    <center>
                        <p>
                            <small style="font-size:14px;">202, Progressive Square, Shahrah-e-Faisal, Nursery,
                                Karachi-75400, Pakistan.
                                <br/>
                                UAN:(021)111-238-222, Phones:(021)34311512-13-14, www.mutualsecurity.net
                            </small>
                        </p>
                    </center>
                </div>

            </div>
        </template>
    </data>
</odoo>