<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="customer_address">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="customer">
                    <div class="article">
                        <div class="page">
                            <div class="row">
                                <br/>
                                <div>
                                    <!--<strong>CS Number:</strong>-->
                                    <span style="font-size:18px" t-esc="customer.cs_number"/>
                                    <br/>

                                    <span style="font-size:18px">
                                        <!--<strong>Name:</strong>-->
                                        <span t-esc="customer.name"/>
                                        <br/>
                                    </span>
                                    <!--<strong>Monitoring Address:</strong> <span t-field="customer.street"/>,<span t-field="customer.street2"/><br/>-->
                                    <span style="font-size:18px">
                                        <t t-if="customer.c_street">
                                            <!--<strong>Address:</strong>-->
                                            <span t-esc="customer.c_street"/>
                                            <br/>
                                            <t t-if="customer.c_street2">
                                                <span t-esc="customer.c_street2"/>
                                            </t>
                                        </t>
                                        <t t-if="customer.c_street==False">
                                            <!--<strong>Address:</strong>-->
                                            <span t-esc="customer.street"/>
                                            <br/>
                                            <t t-if="customer.street2">
                                                <span t-esc="customer.street2"/>
                                            </t>
                                        </t>

                                        <t t-if="customer.city">
                                            <!--<strong>City:</strong>-->
                                            <span t-esc="customer.city"/>
                                            <br/>
                                        </t>
                                    </span>
                                    <t t-if="customer.phone and customer.mobile==False">
                                        <!--<strong>Phone:</strong>-->
                                        <span style="font-size:18px" t-esc="customer.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="customer.mobile and customer.phone==False">
                                        <!--<strong>Mobile:</strong>-->
                                        <span style="font-size:18px" t-esc="customer.mobile"/>
                                        <br/>
                                    </t>
                                    <t t-if="customer.mobile and customer.phone">
                                        <!--<strong>Mobile:</strong>-->
                                        <span style="font-size:18px" t-esc="customer.mobile"/>
                                        <br/>
                                    </t>
                                </div>
                                <br/>
                            </div>
                        </div>
                    </div>
