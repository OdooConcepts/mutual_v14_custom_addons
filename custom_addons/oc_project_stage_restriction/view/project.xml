<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="project_task_type_inherited_form" model="ir.ui.view">
                <field name="name">project.task.type.inherit.form</field>
                <field name="model">project.task.type</field>
                <field name="inherit_id" ref="project.task_type_edit"/>
                <field name="arch" type="xml">
                    <xpath expr="//field[@name='mail_template_id']" position="after">
                       <field name="user_id" widget="many2many_tags"/>
                      </xpath>
                </field>
                </record>
     <record id="project_task_type_inherited_tree" model="ir.ui.view">
                <field name="name">project.task.type.inherit.tree</field>
                <field name="model">project.task.type</field>
                <field name="inherit_id" ref="project.task_type_tree"/>
                <field name="arch" type="xml">
                    <xpath expr="//field[@name='name']" position="after">
                       <field name="user_id" widget="many2many_tags"/>
                      </xpath>
                </field>
                </record>

    <record id="group_stage_user_access" model="res.groups">
            <field name="name">User Group for Stage</field>
    </record>
    <record id="project_stage_access" model="ir.rule">
            <field name="name">Show Stage for only Selected User</field>
            <field name="model_id" ref="project.model_project_task_type" />
            <field name="groups" eval="[(4, ref('oc_project_stage_restriction.group_stage_user_access'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="0" />
            <field name="perm_create" eval="0" />
            <field name="perm_unlink" eval="0" />
        </record>


</odoo>